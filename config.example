# keep-awake-agents config
# Sourced by the daemon on startup. After editing, restart:
#   launchctl kickstart -k gui/$(id -u)/com.keepawake.agents

# How often (seconds) to check for running agents. Default: 15.
POLL_INTERVAL=15

# Extra pgrep -f patterns. The daemon will also keep the Mac awake while
# any process matching one of these is running. ERE syntax, one per line.
# Examples:
#   "long-render-job"
#   "/usr/local/bin/my-trainer"
#   "ffmpeg .*-i .*\.mov"
EXTRA_PATTERNS=()

# Set to 1 to also prevent the display from sleeping (caffeinate -d).
# Default 0 = screen still sleeps / lid still dims, but the system stays awake.
PREVENT_DISPLAY_SLEEP=0

# CPU-idle threshold (percent). When the combined CPU% of all matched processes
# stays below this value for CPU_IDLE_DURATION consecutive polls, the wakelock
# is released and the Mac can sleep — even though the agent processes are still
# running. Set to 0 to disable (always keep awake while processes are running).
#
# NOTE: keep this low-but-nonzero AND keep CPU_IDLE_DURATION large. Claude/Codex
# routinely show near-0% CPU while waiting for an API response; if the duration
# is too short, caffeinate exits during a normal LLM round-trip and the Mac (or
# hotspot connection) drops.
CPU_IDLE_THRESHOLD=5

# Number of consecutive polls below CPU_IDLE_THRESHOLD before going idle.
# At POLL_INTERVAL=5: 120 polls = 10 minutes of sustained inactivity.
# Keep this large enough to outlast any LLM API round-trip (often 30–120 s).
CPU_IDLE_DURATION=120
