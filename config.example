# keep-awake-agents config
# Sourced by the daemon on startup. After editing, restart:
#   launchctl kickstart -k gui/$(id -u)/com.keepawake.agents

# How often (seconds) to check for running agents. Default: 15.
POLL_INTERVAL=15

# Extra pgrep -f patterns. The daemon will also keep the Mac awake while
# any process matching one of these is running. ERE syntax, one per line.
# Examples:
#   "long-render-job"
#   "/usr/local/bin/my-trainer"
#   "ffmpeg .*-i .*\.mov"
EXTRA_PATTERNS=()

# Set to 1 to also prevent the display from sleeping (caffeinate -d).
# Default 0 = screen still sleeps / lid still dims, but the system stays awake.
PREVENT_DISPLAY_SLEEP=0

# CPU-idle threshold (percent). When the combined CPU% of all matched processes
# stays below this value for CPU_IDLE_DURATION consecutive polls, the wakelock
# is released and the Mac can sleep — even though the agent processes are still
# running. Set to 0 to disable (always keep awake while processes are running).
#
# NOTE: keep this low-but-nonzero AND keep CPU_IDLE_DURATION large. Claude/Codex
# routinely show near-0% CPU while waiting for an API response; if the duration
# is too short, caffeinate exits during a normal LLM round-trip and the Mac (or
# hotspot connection) drops.
CPU_IDLE_THRESHOLD=5

# Number of consecutive polls below CPU_IDLE_THRESHOLD before going idle.
# At POLL_INTERVAL=5: 120 polls = 10 minutes of sustained inactivity.
# Keep this large enough to outlast any LLM API round-trip (often 30–120 s).
CPU_IDLE_DURATION=120

# ── Network keepalive ────────────────────────────────────────────────────────
# When NETWORK_KEEPALIVE=1, a background ping runs every NETWORK_KEEPALIVE_INTERVAL
# seconds while the wakelock is active.
#
# Why: cellular hotspots (iPhone/Android) and some Wi-Fi routers auto-disconnect
# clients that send no traffic. With the lid closed on AC power the Mac stays
# awake (caffeinate -s) but sends no packets, so the hotspot drops it within
# ~20–30 s. The ping keeps both sides alive.
#
# NETWORK_KEEPALIVE_HOST  — anything reachable on your current network works.
#   8.8.8.8 (Google DNS) is a safe default. Use your router's LAN IP if you
#   want to avoid going to the internet.
# NETWORK_KEEPALIVE_INTERVAL — 30 s is well below any hotspot idle timeout.
NETWORK_KEEPALIVE=0
NETWORK_KEEPALIVE_HOST=8.8.8.8
NETWORK_KEEPALIVE_INTERVAL=30

# ── iMessage notifications ───────────────────────────────────────────────────
# When NOTIFY_IMESSAGE=1, the daemon sends an iMessage to NOTIFY_TARGET when:
#   1. You unplug while keepalive is active (lid-close will now drop the hotspot)
#   2. Battery drops below NOTIFY_BATTERY_PCT% while on battery
#
# NOTIFY_TARGET — your phone number (+15551234567) or Apple ID email.
#   The Mac's Messages app must be signed in to iMessage.
#   Set this to your own number so alerts go to your iPhone.
#
# NOTIFY_BATTERY_PCT — battery % that triggers the low-battery alert.
#   Default 20. Only fires once per AC cycle (resets when you plug back in).
NOTIFY_IMESSAGE=0
NOTIFY_TARGET=
NOTIFY_BATTERY_PCT=20
